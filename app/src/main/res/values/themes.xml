<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.PantryMinder" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">#4CAF50</item>
        <item name="colorPrimaryDark">#388E3C</item>
        <item name="colorAccent">#4CAF50</item>

        <!-- Backgrounds -->
        <item name="android:windowBackground">#FFFFFF</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:statusBarColor">#388E3C</item>

        <!-- Text -->
        <item name="android:textColorPrimary">#212121</item>
        <item name="android:textColorSecondary">#757575</item>

        <!-- Material Components -->
        <item name="materialButtonStyle">@style/Widget.PantryMinder.Button</item>
        <item name="android:buttonStyle">@style/Widget.PantryMinder.Button</item>
    </style>

    <style name="Widget.PantryMinder.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">#4CAF50</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="cornerRadius">12dp</item>
    </style>
</resources>
